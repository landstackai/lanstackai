# Local test renders (used by scripts/test-vision-*.mjs — do not commit)
.test-render/
.test-render-small/
.test-render-mid/
.test-render-fix/
.test-render-png10/

# All test render directories — local-only debug artifacts.
# Catches future .test-anything dirs without needing per-name entries.
.test-*/

# Test corpus PDFs are broker/appraiser source documents — often
# confidential. Ground-truth JSON labels we hand-author ARE committed
# (test-corpus/ground-truth/*.json) so every prompt change can run
# regression against them. The PDFs themselves stay local-only.
test-corpus/*.pdf
test-corpus/**/*.pdf
test-corpus-results/

# Downloaded parcel data (9GB, lives outside git)
data/
